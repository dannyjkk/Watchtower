# Copy this file to .env and fill in your values
# OpenClaw reads .env from ~/.openclaw/.env

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-xxx
OLLAMA_API_KEY=ollama-local

# Google (gog CLI) keyring password
GOG_KEYRING_PASSWORD=your-keyring-password
HOST=0.0.0.0

# Telegram bot tokens (create via @BotFather)
TELEGRAM_BOT_KALEL=your-main-bot-token
TELEGRAM_BOT_JARVIS=your-jarvis-bot-token
TELEGRAM_BOT_JO=your-jo-bot-token

# OpenClaw gateway auth token (generate a random hex string)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Search API keys
BRAVE_API_KEY=your-brave-api-key
TAVILY_API_KEY=your-tavily-api-key

# Telegram identifiers (get your chat ID from @userinfobot)
DANNY_CHAT_ID=your-telegram-chat-id
HOUSE_GROUP_CHAT_ID=your-group-chat-id

# Tailscale Control UI origin (your Tailscale hostname for OpenClaw web UI)
TAILSCALE_CONTROL_UI_URL=https://your-hostname.tailnet.ts.net
