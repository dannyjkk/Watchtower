            {
              "type": "markdown",
              "content": "{% if is_state('input_boolean.power_cut_active', 'on') %}\n{% set secs = (now().timestamp() - states('input_datetime.power_cut_start') | as_timestamp) | int %}\n{% set h = (secs // 3600) | int %}\n{% set m = ((secs % 3600) // 60) | int %}\nPower is OFF \u2014 out for {% if h > 0 %}{{ h }}h {% endif %}{{ m }}m\n{% else %}\nPower is ON\n{% if states('input_datetime.power_cut_start') not in ['unknown','unavailable',''] %}\nLast cut: {{ states('input_datetime.power_cut_start') | as_timestamp | timestamp_custom('%d %b, %I:%M %p') }}\n{% endif %}\n{% endif %}\n\n---\n{% set total_h = states('sensor.power_cut_duration_7_days') | float(0) %}\n{% set total_m = ((total_h % 1) * 60) | int %}\n{% set total_hh = total_h | int %}\nTotal off in last 7 days: {% if total_hh > 0 %}{{ total_hh }}h {% endif %}{{ total_m }}m"
